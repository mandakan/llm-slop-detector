{
  "name": "pack:structural",
  "version": "0.1.0",
  "description": "Structural LLM tells: 'not X but Y' pivots, sycophantic openers, section-closer cliches, and meta-commentary.",
  "phrases": [
    { "pattern": "\\bnot (just|only|merely|simply) .{1,40}?,? but (also )?\\b", "reason": "negation-pivot -- LLM signature construction" },
    { "pattern": "\\bit(?:'?s| is| was)(?:n'?t| not) (?:just |only |merely )?\\w+[,;]\\s+it(?:'?s| is| was)\\b", "reason": "LLM contrast pivot" },
    { "pattern": "\\blet me (walk you through|break this down|explain|clarify|elaborate)\\b", "reason": "LLM meta-commentary" },
    { "pattern": "\\bhere'?s (the thing|what|why|how)\\b", "reason": "LLM meta-commentary" },
    { "pattern": "\\bto be (clear|honest|frank)\\b", "reason": "LLM hedge opener" },
    { "pattern": "\\b(to put it simply|simply put|in essence|at its core|in short|in a nutshell)\\b", "reason": "LLM summary cliche" },
    { "pattern": "\\b(in summary|to summarize|to recap|in closing)\\b", "reason": "LLM closer cliche" },
    { "pattern": "\\b(that being said|having said that|with that said|with that being said)\\b", "reason": "LLM pivot cliche" },
    { "pattern": "\\bwithout (further ado|wasting any more time)\\b", "reason": "LLM opener cliche" },
    { "pattern": "\\blet'?s (dive|get started|begin|explore|take a look|take a closer look)\\b", "reason": "LLM opener cliche" },
    { "pattern": "\\blet'?s (be honest|face it)\\b", "reason": "LLM opener cliche" },
    { "pattern": "\\b(before we (begin|start|dive in)|first things first)\\b", "reason": "LLM opener cliche" },
    { "pattern": "\\bthis begs the question\\b", "reason": "LLM pivot cliche" },
    { "pattern": "\\byou might be wondering\\b", "reason": "LLM meta-commentary" },
    { "pattern": "\\bas we (can see|(?:will )?explore|delve|discuss)\\b", "reason": "LLM meta-commentary" },
    { "pattern": "\\bin this (article|section|post|guide|piece|chapter), we(?:'?ll| will)\\b", "reason": "LLM meta-commentary" },
    { "pattern": "\\bwe(?:'?ll| will) (explore|discuss|cover|examine|look at)\\b", "reason": "LLM meta-commentary" },
    { "pattern": "\\bthe key (takeaway|point|thing|lesson) (is|to remember|here)\\b", "reason": "LLM summary cliche" },
    { "pattern": "\\b(at the end of the day|when all is said and done)\\b", "reason": "LLM closer cliche" },
    { "pattern": "\\bthe bottom line is\\b", "reason": "LLM closer cliche" },
    { "pattern": "^\\s*(Great|Excellent|Fantastic|Absolutely|Perfect|Wonderful|Certainly)[!.,]", "reason": "sycophantic opener" },
    { "pattern": "^\\s*That'?s an? (excellent|great|fantastic|wonderful|brilliant|insightful)\\b", "reason": "sycophantic opener" },
    { "pattern": "^\\s*You raise\\b", "reason": "sycophantic opener" },
    { "pattern": "^\\s*I('?d| would) (be happy|love) to\\b", "reason": "sycophantic opener" }
  ]
}
