{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["chrome", "node"]
  },
  "include": [
    "src/**/*.ts",
    "../src/core/rules.ts",
    "../src/core/scan.ts",
    "../src/core/comments.ts",
    "../src/core/types.ts"
  ]
}
